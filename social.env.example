# ── Social Media Management ────────────────────────────────────────────────────
# Obtain from the Meta for Developers dashboard (https://developers.facebook.com/)
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here

# The exact redirect URI registered in your Meta app's OAuth settings
META_OAUTH_REDIRECT=https://yourdomain.com/api/social/callback

# 32+ character random string used to derive the AES-256-GCM key for token encryption
# Generate with: openssl rand -base64 32
SOCIAL_TOKEN_ENC_KEY=replace_with_a_long_random_secret

# Secret for authenticating cron/webhook requests (e.g. from Vercel Cron)
# Generate with: openssl rand -hex 32
CRON_SECRET=replace_with_a_long_random_secret

# Tavily API key for trend/news search (https://tavily.com/)
# Leave empty to use built-in mock data in development
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Set to "1" to use MockProvider instead of real Meta Graph API
# Useful in development and CI — allows full social flow without Meta credentials
SOCIAL_MOCK=1
